<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
                             http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>Online Beverage Store</display-name>
    <description>A complete e-commerce platform for selling beverages with customer and admin roles</description>

    <!-- ========== SESSION CONFIGURATION ========== -->
    <session-config>
        <session-timeout>30</session-timeout> <!-- 30 minutes -->
        <cookie-config>
            <http-only>true</http-only>
            <secure>false</secure>
        </cookie-config>
        <tracking-mode>COOKIE</tracking-mode>
    </session-config>

    <!-- ========== FILTERS ========== -->

    <!-- Authentication Filter - protects /customer/* and /admin/* -->
    <filter>
        <filter-name>AuthFilter</filter-name>
        <filter-class>com.beveragestore.filter.AuthFilter</filter-class>
    </filter>

    <!-- Auth Filter Mapping -->
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/customer/*</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/admin/*</url-pattern>
    </filter-mapping>

    <!-- ========== PUBLIC SERVLETS (No Auth Required) ========== -->

    <!-- Product Listing (Public) -->
    <servlet>
        <servlet-name>ProductServlet</servlet-name>
        <servlet-class>com.beveragestore.servlet.ProductServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ProductServlet</servlet-name>
        <url-pattern>/products</url-pattern>
    </servlet-mapping>

    <!-- Product Details (Public) -->
    <servlet>
        <servlet-name>ProductDetailServlet</servlet-name>
        <servlet-class>com.beveragestore.servlet.ProductDetailServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ProductDetailServlet</servlet-name>
        <url-pattern>/product</url-pattern>
    </servlet-mapping>

    <!-- ========== AUTHENTICATION SERVLETS ========== -->

    <!-- Login -->
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.beveragestore.servlet.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <!-- Register -->
    <servlet>
        <servlet-name>RegisterServlet</servlet-name>
        <servlet-class>com.beveragestore.servlet.RegisterServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RegisterServlet</servlet-name>
        <url-pattern>/register</url-pattern>
    </servlet-mapping>

    <!-- Logout -->
    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>com.beveragestore.servlet.LogoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

    <!-- Google Authentication -->
    <servlet>
        <servlet-name>GoogleAuthServlet</servlet-name>
        <servlet-class>com.beveragestore.servlet.GoogleAuthServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>GoogleAuthServlet</servlet-name>
        <url-pattern>/google-auth</url-pattern>
    </servlet-mapping>

    <!-- ========== CUSTOMER SERVLETS ========== -->

    <!-- Shopping Cart -->
    <servlet>
        <servlet-name>CartServlet</servlet-name>
        <servlet-class>com.beveragestore.servlet.CartServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CartServlet</servlet-name>
        <url-pattern>/customer/cart</url-pattern>
    </servlet-mapping>

    <!-- Checkout -->
    <servlet>
        <servlet-name>CheckoutServlet</servlet-name>
        <servlet-class>com.beveragestore.servlet.CheckoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CheckoutServlet</servlet-name>
        <url-pattern>/customer/checkout</url-pattern>
    </servlet-mapping>

    <!-- Order Confirmation -->
    <servlet>
        <servlet-name>OrderConfirmationServlet</servlet-name>
        <servlet-class>com.beveragestore.servlet.OrderConfirmationServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>OrderConfirmationServlet</servlet-name>
        <url-pattern>/customer/order-confirmation</url-pattern>
    </servlet-mapping>

    <!-- Order History -->
    <servlet>
        <servlet-name>OrderHistoryServlet</servlet-name>
        <servlet-class>com.beveragestore.servlet.OrderHistoryServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>OrderHistoryServlet</servlet-name>
        <url-pattern>/customer/orders</url-pattern>
    </servlet-mapping>

    <!-- Order Detail -->
    <servlet>
        <servlet-name>OrderDetailServlet</servlet-name>
        <servlet-class>com.beveragestore.servlet.OrderDetailServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>OrderDetailServlet</servlet-name>
        <url-pattern>/customer/order-detail</url-pattern>
    </servlet-mapping>

    <!-- ========== ADMIN SERVLETS ========== -->

    <!-- Admin Dashboard -->
    <servlet>
        <servlet-name>AdminDashboardServlet</servlet-name>
        <servlet-class>com.beveragestore.servlet.AdminDashboardServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminDashboardServlet</servlet-name>
        <url-pattern>/admin/dashboard</url-pattern>
    </servlet-mapping>

    <!-- Admin Products Management -->
    <servlet>
        <servlet-name>AdminProductServlet</servlet-name>
        <servlet-class>com.beveragestore.servlet.AdminProductServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminProductServlet</servlet-name>
        <url-pattern>/admin/products</url-pattern>
    </servlet-mapping>

    <!-- Admin Orders Management -->
    <servlet>
        <servlet-name>AdminOrderServlet</servlet-name>
        <servlet-class>com.beveragestore.servlet.AdminOrderServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminOrderServlet</servlet-name>
        <url-pattern>/admin/orders</url-pattern>
    </servlet-mapping>

    <!-- ========== ERROR PAGES ========== -->

    <error-page>
        <error-code>404</error-code>
        <location>/WEB-INF/views/404.jsp</location>
    </error-page>

    <error-page>
        <error-code>403</error-code>
        <location>/WEB-INF/views/403.jsp</location>
    </error-page>

    <error-page>
        <error-code>500</error-code>
        <location>/WEB-INF/views/error.jsp</location>
    </error-page>

    <!-- ========== JSP CONFIGURATION ========== -->

    <jsp-config>
        <taglib>
            <taglib-uri>http://java.sun.com/jsp/jstl/core</taglib-uri>
            <taglib-location>/WEB-INF/lib/c.tld</taglib-location>
        </taglib>
    </jsp-config>

    <!-- ========== WELCOME FILES ========== -->
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
        <welcome-file>index.html</welcome-file>
    </welcome-file-list>

</web-app>
